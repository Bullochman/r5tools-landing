#     try:
#         subprocess.run(
#             ["python3", "ping_sitemap.py"],
#             cwd=ping_dir,
#             check=False,
#             timeout=90,
#         )
#     except Exception as e:  # noqa: BLE001
#         print(f"[warn] post-build sitemap ping failed: {e}")
#
# The ping script's own mtime-state guard prevents double-firing if the SEO
# build didn't actually touch sitemap.xml.
